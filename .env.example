# Copy to .env and fill in real values. Do not commit .env.
# Used by docker-compose.yml (backend + database).

# PostgreSQL
DB_USERNAME=catpair
DB_PASSWORD=change-me

# Backend: use a long random string (32+ chars) for the JWT signing secret
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Published app port (frontend container)
APP_PORT=80

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost
